<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="@dimen/bottom_nav_height"
    android:orientation="horizontal"
    android:background="@color/background"
    android:elevation="@dimen/elevation_md"
    android:weightSum="4">

    <!-- Home -->
    <LinearLayout
        android:id="@+id/nav_home"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="@dimen/icon_lg"
            android:layout_height="@dimen/icon_lg"
            android:src="@drawable/ic_view_list"
            android:contentDescription="@string/nav_home"
            android:tint="@color/primary_brand" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_home"
            android:textSize="@dimen/font_xs"
            android:textColor="@color/primary_brand"
            android:layout_marginTop="@dimen/spacing_xs" />
    </LinearLayout>

    <!-- Messages -->
    <LinearLayout
        android:id="@+id/nav_messages"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="@dimen/icon_lg"
            android:layout_height="@dimen/icon_lg"
            android:src="@drawable/ic_view_grid_compact"
            android:contentDescription="@string/nav_messages"
            android:tint="@color/muted_foreground" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_messages"
            android:textSize="@dimen/font_xs"
            android:textColor="@color/muted_foreground"
            android:layout_marginTop="@dimen/spacing_xs" />
    </LinearLayout>

    <!-- Search -->
    <LinearLayout
        android:id="@+id/nav_search"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="@dimen/icon_lg"
            android:layout_height="@dimen/icon_lg"
            android:src="@drawable/ic_sort_az"
            android:contentDescription="@string/nav_search"
            android:tint="@color/muted_foreground" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_search"
            android:textSize="@dimen/font_xs"
            android:textColor="@color/muted_foreground"
            android:layout_marginTop="@dimen/spacing_xs" />
    </LinearLayout>

    <!-- Profile -->
    <LinearLayout
        android:id="@+id/nav_profile"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="@dimen/icon_lg"
            android:layout_height="@dimen/icon_lg"
            android:src="@drawable/ic_view_grid_medium"
            android:contentDescription="@string/nav_profile"
            android:tint="@color/muted_foreground" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_profile"
            android:textSize="@dimen/font_xs"
            android:textColor="@color/muted_foreground"
            android:layout_marginTop="@dimen/spacing_xs" />
    </LinearLayout>

</LinearLayout>
