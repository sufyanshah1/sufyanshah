<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="@dimen/header_height"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="@dimen/spacing_lg"
    android:paddingVertical="@dimen/spacing_md"
    android:background="@color/background"
    android:elevation="@dimen/elevation_sm">

    <!-- Search Bar -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="@drawable/search_bar_background"
        android:paddingHorizontal="@dimen/spacing_lg"
        android:paddingVertical="@dimen/spacing_md">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:id="@+id/search_container">

            <!-- Search Icon -->
            <ImageView
                android:layout_width="@dimen/icon_lg"
                android:layout_height="@dimen/icon_lg"
                android:src="@drawable/ic_search"
                android:contentDescription="@string/search_calls"
                android:tint="@color/muted_foreground"
                android:layout_marginEnd="@dimen/spacing_md" />

            <!-- Search Input -->
            <EditText
                android:id="@+id/search_input"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@null"
                android:hint="@string/search_calls"
                android:textSize="@dimen/font_sm"
                android:textColor="@color/foreground"
                android:textColorHint="@color/muted_foreground"
                android:inputType="text"
                android:maxLines="1" />

            <!-- Clear Button -->
            <ImageButton
                android:id="@+id/search_clear_btn"
                android:layout_width="@dimen/button_width_icon"
                android:layout_height="@dimen/button_width_icon"
                android:src="@drawable/ic_close"
                android:contentDescription="@string/search_calls"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/muted_foreground"
                android:visibility="gone" />
        </LinearLayout>
    </FrameLayout>

    <!-- Theme Toggle Button -->
    <ImageButton
        android:id="@+id/theme_toggle_btn"
        android:layout_width="@dimen/button_width_icon"
        android:layout_height="@dimen/button_width_icon"
        android:layout_marginStart="@dimen/spacing_md"
        android:src="@drawable/ic_moon"
        android:contentDescription="@string/toggle_theme"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:tint="@color/foreground"
        android:scaleType="centerInside" />

    <!-- Add Contact Button -->
    <ImageButton
        android:id="@+id/add_contact_btn"
        android:layout_width="@dimen/button_width_icon"
        android:layout_height="@dimen/button_width_icon"
        android:layout_marginStart="@dimen/spacing_md"
        android:src="@drawable/ic_plus"
        android:contentDescription="@string/add_contact"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:tint="@color/foreground"
        android:scaleType="centerInside" />

    <!-- More Options Menu Button -->
    <ImageButton
        android:id="@+id/menu_btn"
        android:layout_width="@dimen/button_width_icon"
        android:layout_height="@dimen/button_width_icon"
        android:layout_marginStart="@dimen/spacing_md"
        android:src="@drawable/ic_more_vertical"
        android:contentDescription="@string/more_options"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:tint="@color/foreground"
        android:scaleType="centerInside" />

</LinearLayout>
