<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/background"
    android:paddingTop="@dimen/spacing_lg"
    android:paddingBottom="@dimen/spacing_md"
    android:elevation="@dimen/elevation_sm">

    <!-- Section Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/recommended"
        android:textSize="@dimen/font_xs"
        android:textStyle="bold"
        android:textColor="@color/muted_foreground"
        android:letterSpacing="0.05"
        android:paddingHorizontal="@dimen/spacing_lg"
        android:paddingBottom="@dimen/spacing_md" />

    <!-- Horizontal Scrollable List -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="@dimen/spacing_lg"
        android:paddingBottom="@dimen/spacing_xs">

        <LinearLayout
            android:id="@+id/recommended_list"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:spacing="@dimen/spacing_lg" />
    </HorizontalScrollView>

</LinearLayout>
